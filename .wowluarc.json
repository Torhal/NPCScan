{
    "diagnostics": {
        "enable": [
            "implicit-nil-return",
            "missing-param-annotation",
            "missing-return-annotation",
            "need-check-nil",
            "unknown-field-type",
            "unknown-local-type",
            "unknown-param-type",
            "unknown-return-type"
        ],
        "severity": {
            "code-after-break": "error",
            "empty-block": "warning",
            "inject-field": "error",
            "implicit-nil-return": "warning",
            "not-precedence": "error",
            "redefined-local": "error",
            "redundant-return": "error",
            "shadowed-local": "error",
            "unknown-field-type": "warning",
            "unknown-local-type": "warning",
            "unknown-param-type": "warning",
            "unknown-return-type": "warning",
            "unreachable-code": "error"
        }
    },
    "flavors": [
        "retail"
    ],
    "library": [
        "Libraries"
    ]
}